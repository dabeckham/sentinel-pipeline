# =============================================================================
# Sentinel Pipeline — .gitignore
# =============================================================================

# Environment / secrets — NEVER commit these
.env
*.env
!.env.example

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
pip-wheel-metadata/

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/
.dmypy.json

# Node / UI
ui/node_modules/
ui/dist/
ui/.vite/
*.tsbuildinfo

# IDE / editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Docker
*.log

# YOLO model weights (large binary files — download at runtime)
*.pt
*.onnx
*.engine
models/

# MinIO local data (if running locally for dev)
minio-data/

# Postgres local data
postgres-data/

# RabbitMQ local data
rabbitmq-data/

# Temporary / test files
tmp/
temp/
scratch/
